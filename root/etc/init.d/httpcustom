#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1

# Core Logic: ตรวจสอบและปรับจูน Kernel ก่อนเริ่ม Tunneling
apply_kernel_tuning() {
    local target_qdisc="fq"
    local target_cc="bbr"

    # TCP BBR สำหรับการเชื่อมต่อ 5G ที่มีค่า Latency แกว่ง
    local current_cc=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)
    if [ "$current_cc" != "$target_cc" ]; then
        sysctl -w net.core.default_qdisc=$target_qdisc >/dev/null 2>&1
        sysctl -w net.ipv4.tcp_congestion_control=$target_cc >/dev/null 2>&1
        logger -t "httpcustom" "Kernel Tuning: TCP BBR enabled."
    fi

    # TCP MSS Clamping ป้องกัน Packet Drop จาก Overhead ของ IP Header ที่ซ้อนกันใน Tunnel
    iptables -t mangle -C FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu 2>/dev/null || \
    iptables -t mangle -A FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu
}

start_service() {
    config_load httpcustom
    local enabled
    config_get_bool enabled main enabled 0
    
    [ "$enabled" -eq 1 ] || return 0

    procd_open_instance
    # สมมติฐาน: โปรแกรมแกนหลักคือ httpcustom_core_daemon (คุณต้องเขียน Backend แยกต่างหาก)
    procd_set_param command /usr/bin/httpcustom_core_daemon --config /etc/config/httpcustom
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn
    procd_close_instance

    apply_kernel_tuning
    logger -t "httpcustom" "Service started. MTU/MSS & Kernel optimizations applied."
}

stop_service() {
    iptables -t mangle -D FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu 2>/dev/null
    logger -t "httpcustom" "Service stopped. Iptables rules cleaned."
}
